{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "POSMerahPutih",
  "version": "1.5.0",
  "identifier": "id.posmerahputih.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "POSMerahPutih — Kasir",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "POSMerahPutih",
    "copyright": "© 2026 POSMerahPutih",
    "category": "Business",
    "shortDescription": "Kasir UMKM local-first (offline).",
    "longDescription": "POSMerahPutih — aplikasi Point of Sale local-first untuk UMKM retail & F&B Indonesia. Seluruh data tersimpan di perangkat (SQLite) & berfungsi penuh tanpa internet.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Indonesian", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
